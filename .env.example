# Operiq AI Configuration
# Copy this file to .env and fill in your values

# AI Provider (required)
# Get your API key from your AI provider (e.g., OpenAI, OpenRouter, etc.)
AI_API_KEY=your-api-key-here

# AI Model (optional, defaults to gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# AI Base URL (optional, for custom endpoints like OpenRouter)
# Leave blank to use the default OpenAI endpoint
# AI_BASE_URL=https://api.openai.com/v1
